[sub_resource type="Shader" id="1_spotlight_shader"]
code = "shader_type canvas_item;

uniform vec2 center = vec2(0.5, 0.78);
uniform float radius = 0.14;
uniform float softness = 0.18;
uniform float darkness = 0.96;

void fragment() {
	float dist = distance(UV, center);
	float alpha = smoothstep(radius, radius + softness, dist) * darkness;
	COLOR = vec4(0.0, 0.0, 0.0, alpha);
}
"

