[node name="DescriptionLabel" type="Label" parent="VBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.78, 0.78, 0.82, 1)
theme_override_font_sizes/font_size = 14
text = "Your name is Max. You came here to study abroad with your friend Jennet — until she vanished without a trace. No warning, no goodbye. You searched everywhere, asked everyone. Nothing.

One evening, exhausted from worry, you collapse into sleep. When you open your eyes, you are back at the university. The hallways stretch endlessly before you, silent except for your own heartbeat. Something is wrong. The air feels heavy. The lights flicker. This place is... haunted.

A shadow appears before you, its voice echoing through the empty corridors:
'You are looking for your friend? Solve the challenges. Pass the courses. Reach the exam hall — and you shall know where she is.'

The shadow fades before you can respond. Is this real? Is this a dream? You do not know. But if solving these mysteries is your only chance to find Jennet, you will take it.

Be careful. Not everything in this university is what it seems."
horizontal_alignment = 1
autowrap_mode = 2

[node name="StartButton" type="Button" parent="VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 22
text = "Start Game"
